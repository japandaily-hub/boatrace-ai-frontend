# ─── ローカル開発用 ────────────────────────────────────────
# .env.example を .env.local にコピーして使用してください
# cp .env.example .env.local

# AWS API Gateway エンドポイント（本番 API）
# 未設定の場合は lib/mock_data.ts のモックデータを使用
NEXT_PUBLIC_API_BASE=https://xxxxxxxxxx.execute-api.ap-northeast-1.amazonaws.com/prod

# ─── Vercel 環境変数（Vercel ダッシュボードで設定） ─────────
# Settings → Environment Variables
# Key: NEXT_PUBLIC_API_BASE
# Value: https://your-api-gateway-url.execute-api.ap-northeast-1.amazonaws.com/prod
# Environment: Production, Preview, Development
